// Timer is configured for 1us ticks and 20ms period:
// PSC=79, ARR=19999  -> CCR value equals pulse width in microseconds.
static void servo_set_pulse_us(uint16_t pulse_us)
{
  if (pulse_us < 1000) pulse_us = 1000;
  if (pulse_us > 2000) pulse_us = 2000;
  __HAL_TIM_SET_COMPARE(SERVO_TIM, SERVO_CH, pulse_us);
}

// angle: 0..180  -> 1000..2000 us
void servo_set_angle(float angle)
{
  if (angle < 0.0f) angle = 0.0f;
  if (angle > 180.0f) angle = 180.0f;

  float pulse_us_f = 1000.0f + (angle / 180.0f) * 1000.0f;
  servo_set_pulse_us((uint16_t)(pulse_us_f + 0.5f));
}

// If your IR sensors output LOW when they see BLACK, set this to 1.
// If they output HIGH on black, set to 0.
#define IR_BLACK_IS_LOW   1

// Enable DWT cycle counter for microsecond timing (works on Cortex-M4 like L476)
static void dwt_init(void)
{
  // Enable trace
  CoreDebug->DEMCR |= CoreDebug_DEMCR_TRCENA_Msk;
  // Reset cycle counter
  DWT->CYCCNT = 0;
  // Enable cycle counter
  DWT->CTRL |= DWT_CTRL_CYCCNTENA_Msk;
}

// Returns microseconds since boot using CPU cycle counter
static inline uint32_t micros(void)
{
  // SystemCoreClock is updated by SystemClock_Config
  return (uint32_t)(DWT->CYCCNT / (SystemCoreClock / 1000000U));
}

// Read one IR sensor (1..8). Returns true if it sees BLACK.
static bool ir_read_black(uint8_t idx)
{
  GPIO_PinState s;
  switch (idx)
  {
    case 1: s = HAL_GPIO_ReadPin(IR_in_1_GPIO_Port, IR_in_1_Pin); break;
    case 2: s = HAL_GPIO_ReadPin(IR_in_2_GPIO_Port, IR_in_2_Pin); break;
    case 3: s = HAL_GPIO_ReadPin(IR_in_3_GPIO_Port, IR_in_3_Pin); break;
    case 4: s = HAL_GPIO_ReadPin(IR_in_4_GPIO_Port, IR_in_4_Pin); break;
    case 5: s = HAL_GPIO_ReadPin(IR_in_5_GPIO_Port, IR_in_5_Pin); break;
    case 6: s = HAL_GPIO_ReadPin(IR_in_6_GPIO_Port, IR_in_6_Pin); break;
    case 7: s = HAL_GPIO_ReadPin(IR_in_7_GPIO_Port, IR_in_7_Pin); break;
    case 8: s = HAL_GPIO_ReadPin(IR_in_8_GPIO_Port, IR_in_8_Pin); break;
    default: return false;
  }

#if IR_BLACK_IS_LOW
  return (s == GPIO_PIN_RESET);
#else
  return (s == GPIO_PIN_SET);
#endif
}

// Returns an 8-bit mask of IR sensors detecting BLACK.
// bit0 = IR1 ... bit7 = IR8
static uint8_t ir_read_mask(void)
{
  uint8_t m = 0;
  for (uint8_t i = 1; i <= 8; i++)
  {
    if (ir_read_black(i)) m |= (1u << (i - 1));
  }
  return m;
}

// HC-SR04: trigger pulse (10us HIGH)
static void us_trigger(void)
{
  HAL_GPIO_WritePin(US_trig_GPIO_Port, US_trig_Pin, GPIO_PIN_RESET);
  // short settle
  for (volatile int i = 0; i < 100; i++) { __NOP(); }

  HAL_GPIO_WritePin(US_trig_GPIO_Port, US_trig_Pin, GPIO_PIN_SET);
  uint32_t t0 = micros();
  while ((micros() - t0) < 10) { /* wait ~10us */ }
  HAL_GPIO_WritePin(US_trig_GPIO_Port, US_trig_Pin, GPIO_PIN_RESET);
}

// Measure echo pulse width in microseconds using GPIO polling.
// Returns 0 on timeout.
static uint32_t us_echo_pulse_us(uint32_t timeout_us)
{
  uint32_t start_wait = micros();

  // Wait for rising edge
  while (HAL_GPIO_ReadPin(US_echo_GPIO_Port, US_echo_Pin) == GPIO_PIN_RESET)
  {
    if ((micros() - start_wait) > timeout_us) return 0;
  }

  uint32_t t_rise = micros();

  // Wait for falling edge
  while (HAL_GPIO_ReadPin(US_echo_GPIO_Port, US_echo_Pin) == GPIO_PIN_SET)
  {
    if ((micros() - t_rise) > timeout_us) return 0;
  }

  uint32_t t_fall = micros();
  return (t_fall - t_rise);
}

// Returns distance in millimeters. Returns 0 on timeout/invalid.
static uint32_t us_read_distance_mm(void)
{
  us_trigger();

  // Typical max range ~4m => echo up to ~23200us. Use 30000us timeout.
  uint32_t pw = us_echo_pulse_us(30000);
  if (pw == 0) return 0;

  // Speed of sound approx 343 m/s => 0.343 mm/us
  // Distance = (pw_us * 0.343) / 2
  // Use integer math: (pw * 343) / 2000 gives mm (since 0.343/2 = 0.1715)
  return (pw * 343U) / 2000U;
}

/* ================= MOTOR CONTROL ================= */

// Uses existing direction GPIO pins from your CubeMX project:
// MOTOR_L_DIR_Pin and MTOR_R_DIR_Pin on GPIOB
void Motor_Init(void)
{
  // Start PWM output for motor speed control
  HAL_TIM_PWM_Start(MOTOR_PWM_TIM, MOTOR_PWM_CH);

  // Default stopped
  __HAL_TIM_SET_COMPARE(MOTOR_PWM_TIM, MOTOR_PWM_CH, 0);
  HAL_GPIO_WritePin(GPIOB, MOTOR_L_DIR_Pin, GPIO_PIN_RESET);
  HAL_GPIO_WritePin(GPIOB, MTOR_R_DIR_Pin, GPIO_PIN_RESET);
}

// Set motor speed as percentage 0..100
void Motor_SetSpeed(uint8_t speed)
{
  if (speed > 100) speed = 100;

  // TIM3 currently has ARR = 65535 in your config
  uint32_t arr = __HAL_TIM_GET_AUTORELOAD(MOTOR_PWM_TIM);
  uint32_t pulse = (speed * (arr + 1U)) / 100U;

  if (pulse > arr) pulse = arr;
  __HAL_TIM_SET_COMPARE(MOTOR_PWM_TIM, MOTOR_PWM_CH, pulse);
}

// direction = 0 forward, 1 reverse
void Motor_SetDirection(uint8_t direction)
{
  if (direction == MOTOR_DIR_FORWARD)
  {
    HAL_GPIO_WritePin(GPIOB, MOTOR_L_DIR_Pin, GPIO_PIN_SET);
    HAL_GPIO_WritePin(GPIOB, MTOR_R_DIR_Pin, GPIO_PIN_RESET);
  }
  else
  {
    HAL_GPIO_WritePin(GPIOB, MOTOR_L_DIR_Pin, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(GPIOB, MTOR_R_DIR_Pin, GPIO_PIN_SET);
  }
}

void Motor_Stop(void)
{
  __HAL_TIM_SET_COMPARE(MOTOR_PWM_TIM, MOTOR_PWM_CH, 0);
  HAL_GPIO_WritePin(GPIOB, MOTOR_L_DIR_Pin, GPIO_PIN_RESET);
  HAL_GPIO_WritePin(GPIOB, MTOR_R_DIR_Pin, GPIO_PIN_RESET);
}

